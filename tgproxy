#!/usr/bin/env bash
set -e

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$DIR/src/common.sh"
source "$DIR/src/setup.sh"
source "$DIR/src/actions.sh"

COMMAND="${1:-help}"

case "$COMMAND" in
  install)
    action_install
    ;;
  link)
    action_link
    ;;
  restart)
    action_restart
    ;;
  status)
    action_status
    ;;
  help|--help|-h)
    action_help
    ;;
  *)
    echo "Unknown command: $COMMAND"
    action_help
    exit 1
    ;;
esac