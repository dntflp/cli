#!/usr/bin/env bash
set -e

# Hardcode the known installation directory to avoid symlink/path resolution issues
DIR="/opt/tgproxy"

source "$DIR/src/common.sh"
source "$DIR/src/setup.sh"
source "$DIR/src/actions.sh"

COMMAND="${1:-help}"

case "$COMMAND" in
  install)
    action_install
    ;;
  install-docker)
    action_install_docker
    ;;
  link)
    action_link
    ;;
  restart)
    action_restart
    ;;
  status)
    action_status
    ;;
  help|--help|-h)
    action_help
    ;;
  *)
    echo "Unknown command: $COMMAND"
    action_help
    exit 1
    ;;
esac